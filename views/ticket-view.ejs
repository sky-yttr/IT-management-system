<%- include('partials/header') %>

<% function statusChip(s) {
    const map = {
        'OPEN':         ['bg-status-open-bg',   'text-status-open-text',   'Open'],
        'IN_PROGRESS':  ['bg-status-prog-bg',   'text-status-prog-text',   'In Progress'],
        'PENDING_USER': ['bg-status-pend-bg',   'text-status-pend-text',   'Pending'],
        'CLOSED':       ['bg-status-closed-bg', 'text-status-closed-text', 'Closed'],
    };
    return map[s] || ['bg-gray-200', 'text-gray-700', s];
} %>
<%
const [bg, txt, lbl] = statusChip(ticket.currentStatus);
function initials(name) {
    return name.split(' ').map(s => s[0]).slice(0, 2).join('').toUpperCase();
}
%>

<div class="grid grid-cols-3 gap-6">

    <!-- MAIN COLUMN (2/3) -->
    <div class="col-span-2 space-y-4">

        <% if (flash) { %>
        <div class="p-3 <%= flash.type === 'success' ? 'bg-secondary-light/40 border-secondary text-secondary' : 'bg-error-light border-error/30 text-error' %> border text-sm rounded flex items-start gap-2">
            <span class="material-symbols-outlined text-base"><%= flash.type === 'success' ? 'check_circle' : 'error' %></span>
            <span><%= flash.message %></span>
        </div>
        <% } %>

        <!-- Ticket header card -->
        <div class="bg-surface-card border border-outline-var rounded-lg p-6">
            <div class="flex items-start justify-between mb-5">
                <div class="flex items-center gap-3">
                    <span class="font-mono text-xs font-semibold text-on-surface-var bg-surface-low px-2 py-1 rounded">#TKT-<%= String(ticket.id).padStart(4, '0') %></span>
                    <h1 class="text-2xl font-bold"><%= ticket.title %></h1>
                </div>
                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium <%= bg %> <%= txt %>">
                    <span class="material-symbols-outlined text-sm"><%= ticket.currentStatus === 'CLOSED' ? 'check_circle' : 'sync' %></span>
                    <%= lbl.toUpperCase() %>
                </span>
            </div>
            <div class="grid grid-cols-3 gap-4 text-sm border-t border-outline-var pt-4">
                <div>
                    <div class="text-[11px] uppercase tracking-wider text-on-surface-var font-semibold">Submitter</div>
                    <div class="mt-1 flex items-center gap-2">
                        <span class="material-symbols-outlined text-base text-on-surface-var">person</span>
                        <span><%= submitter.name %></span>
                    </div>
                </div>
                <div>
                    <div class="text-[11px] uppercase tracking-wider text-on-surface-var font-semibold">Priority</div>
                    <div class="mt-1 flex items-center gap-1">
                        <% if (ticket.priority === 'HIGH' || ticket.priority === 'CRITICAL') { %>
                            <span class="material-symbols-outlined text-base text-error">priority_high</span>
                            <span class="text-error font-medium"><%= ticket.priority.charAt(0) + ticket.priority.slice(1).toLowerCase() %></span>
                        <% } else { %>
                            <span class="material-symbols-outlined text-base text-on-surface-var">remove</span>
                            <span><%= ticket.priority.charAt(0) + ticket.priority.slice(1).toLowerCase() %></span>
                        <% } %>
                    </div>
                </div>
                <div>
                    <div class="text-[11px] uppercase tracking-wider text-on-surface-var font-semibold">Category</div>
                    <div class="mt-1 flex items-center gap-2">
                        <span class="material-symbols-outlined text-base text-on-surface-var">category</span>
                        <span><%= ticket.category.charAt(0) + ticket.category.slice(1).toLowerCase() %></span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Description card -->
        <div class="bg-surface-card border border-outline-var rounded-lg p-6">
            <div class="text-[11px] uppercase tracking-wider text-on-surface-var font-semibold mb-3">Description</div>
            <p class="text-sm leading-relaxed whitespace-pre-wrap"><%= ticket.description %></p>
        </div>

        <!-- Resolution box (if closed) -->
        <% if (resolution) { %>
        <div class="bg-status-closed-bg/40 border border-status-closed-text/30 rounded-lg p-6">
            <div class="flex items-center gap-2 text-status-closed-text font-semibold mb-2">
                <span class="material-symbols-outlined">check_circle</span>
                Resolution
            </div>
            <p class="text-sm leading-relaxed whitespace-pre-wrap text-on-surface"><%= resolution.content %></p>
            <p class="text-xs text-on-surface-var mt-3">Resolved by <span class="font-semibold"><%= resolution.resolver_name %></span> on <%= resolution.resolved_at %></p>
        </div>
        <% } %>

        <!-- Activity Feed -->
        <div>
            <h2 class="text-lg font-semibold mb-3">Activity Feed</h2>
            <% if (comments.length === 0) { %>
                <div class="bg-surface-card border border-outline-var rounded-lg p-6 text-center text-sm text-on-surface-var">
                    No comments yet.
                </div>
            <% } else { %>
                <div class="space-y-3">
                <% comments.forEach(c => {
                    const isAgent = c.author_role === 'SUPPORT_AGENT' || c.author_role === 'IT_MANAGER';
                    const accentColor = isAgent ? 'border-secondary' : 'border-primary';
                    const bgColor = isAgent ? 'bg-secondary-light' : 'bg-primary-light';
                    const txtColor = isAgent ? 'text-secondary' : 'text-primary';
                %>
                    <div class="bg-surface-card border border-outline-var border-l-4 <%= accentColor %> rounded p-4">
                        <div class="flex items-start gap-3">
                            <div class="w-9 h-9 rounded <%= bgColor %> <%= txtColor %> flex items-center justify-center text-xs font-bold"><%= initials(c.author_name) %></div>
                            <div class="flex-1">
                                <div class="flex items-center justify-between mb-1">
                                    <div class="flex items-center gap-2">
                                        <span class="font-semibold text-sm"><%= c.author_name %></span>
                                        <span class="text-[10px] uppercase tracking-wider font-semibold px-1.5 py-0.5 rounded <%= bgColor %> <%= txtColor %>">
                                            <%= c.author_role === 'END_USER' ? 'User' : (c.author_role === 'SUPPORT_AGENT' ? 'Agent' : 'Manager') %>
                                        </span>
                                    </div>
                                    <span class="text-xs text-on-surface-var font-mono"><%= c.created_at %></span>
                                </div>
                                <p class="text-sm whitespace-pre-wrap"><%= c.content %></p>
                            </div>
                        </div>
                    </div>
                <% }) %>
                </div>
            <% } %>
        </div>

        <!-- Internal Response / Note + Action Bar -->
        <% if (ticket.currentStatus !== 'CLOSED') { %>
        <div class="bg-surface-card border border-outline-var rounded-lg p-6">
            <form method="post" action="/tickets/<%= ticket.id %>/comments">
                <div class="text-[11px] uppercase tracking-wider text-on-surface-var font-semibold mb-2">Add Comment</div>
                <textarea name="content" required rows="3"
                          placeholder="Type your response here..."
                          class="w-full px-3 py-2.5 border border-outline-var rounded text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary resize-none"></textarea>
                <div class="mt-3 flex items-center justify-end">
                    <button type="submit"
                            class="bg-primary hover:bg-primary-dark text-white text-xs font-semibold uppercase tracking-wider px-5 py-2 rounded flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-base">send</span>
                        Post Comment
                    </button>
                </div>
            </form>
        </div>

        <!-- Agent / Manager status actions -->
        <% if ((currentUser.role === 'SUPPORT_AGENT' || currentUser.role === 'IT_MANAGER')) { %>
            <% if (ticket.currentStatus === 'IN_PROGRESS') { %>
            <div class="bg-surface-card border border-outline-var rounded-lg p-6 space-y-4">
                <div class="text-[11px] uppercase tracking-wider text-on-surface-var font-semibold">Agent Actions</div>
                <div class="flex flex-wrap gap-3">
                    <form method="post" action="/tickets/<%= ticket.id %>/status" class="inline">
                        <input type="hidden" name="newStatus" value="PENDING_USER">
                        <button type="submit"
                                class="border border-outline-var hover:bg-surface-low text-on-surface text-xs font-semibold uppercase tracking-wider px-4 py-2 rounded flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-base">schedule</span>
                            Wait for User
                        </button>
                    </form>
                </div>

                <details class="border-t border-outline-var pt-4">
                    <summary class="cursor-pointer flex items-center justify-between text-xs font-semibold uppercase tracking-wider text-error">
                        <span class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-base">task_alt</span>
                            Close Ticket with Resolution (BR-01)
                        </span>
                        <span class="material-symbols-outlined text-base">expand_more</span>
                    </summary>
                    <form method="post" action="/tickets/<%= ticket.id %>/close" class="mt-4 space-y-3">
                        <textarea name="resolutionContent" required rows="3"
                                  placeholder="Describe how the issue was resolved (required to close)"
                                  class="w-full px-3 py-2.5 border border-outline-var rounded text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary resize-none"></textarea>
                        <button type="submit"
                                class="bg-error hover:bg-red-800 text-white text-xs font-semibold uppercase tracking-wider px-4 py-2 rounded flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-base">close</span>
                            Close Ticket
                        </button>
                    </form>
                </details>
            </div>
            <% } else if (ticket.currentStatus === 'PENDING_USER') { %>
            <div class="bg-surface-card border border-outline-var rounded-lg p-6">
                <div class="text-[11px] uppercase tracking-wider text-on-surface-var font-semibold mb-3">Agent Actions</div>
                <form method="post" action="/tickets/<%= ticket.id %>/status">
                    <input type="hidden" name="newStatus" value="IN_PROGRESS">
                    <button type="submit"
                            class="bg-primary hover:bg-primary-dark text-white text-xs font-semibold uppercase tracking-wider px-4 py-2 rounded flex items-center gap-1.5">
                        <span class="material-symbols-outlined text-base">play_arrow</span>
                        Resume Work
                    </button>
                </form>
            </div>
            <% } %>
        <% } %>
        <% } else { %>
            <!-- Closed ticket - BR-05 -->
            <div class="bg-surface-low border border-outline-var rounded-lg p-4 text-sm text-on-surface-var flex items-center gap-2">
                <span class="material-symbols-outlined text-base">lock</span>
                <span>This ticket is closed. Comments are read-only per <strong>BR-05</strong>.</span>
            </div>

            <!-- IT Manager reopen action -->
            <% if (currentUser.role === 'IT_MANAGER') { %>
            <div class="bg-surface-card border border-outline-var rounded-lg p-6">
                <details>
                    <summary class="cursor-pointer flex items-center justify-between text-xs font-semibold uppercase tracking-wider text-primary">
                        <span class="flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-base">restart_alt</span>
                            Reopen Ticket (BR-06)
                        </span>
                        <span class="material-symbols-outlined text-base">expand_more</span>
                    </summary>
                    <form method="post" action="/tickets/<%= ticket.id %>/reopen" class="mt-4 space-y-3">
                        <textarea name="reason" required rows="3"
                                  placeholder="Reason for reopening (mandatory per BR-06)"
                                  class="w-full px-3 py-2.5 border border-outline-var rounded text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary resize-none"></textarea>
                        <button type="submit"
                                class="bg-primary hover:bg-primary-dark text-white text-xs font-semibold uppercase tracking-wider px-4 py-2 rounded flex items-center gap-1.5">
                            <span class="material-symbols-outlined text-base">restart_alt</span>
                            Reopen
                        </button>
                    </form>
                </details>
            </div>
            <% } %>
        <% } %>

    </div>

    <!-- SIDEBAR (1/3) -->
    <aside class="space-y-4">

        <!-- Assignment card -->
        <div class="bg-surface-card border border-outline-var rounded-lg p-5">
            <div class="text-[11px] uppercase tracking-wider text-on-surface-var font-semibold mb-3">Assignment</div>
            <% if (assignment) { %>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded bg-secondary-light text-secondary flex items-center justify-center text-sm font-bold"><%= initials(assignment.agent_name) %></div>
                    <div>
                        <div class="font-semibold text-sm"><%= assignment.agent_name %></div>
                        <div class="text-xs text-on-surface-var">Support Agent</div>
                    </div>
                </div>
                <div class="text-[11px] text-on-surface-var font-mono mt-3">Assigned <%= assignment.assigned_at %></div>
            <% } else { %>
                <p class="text-sm text-on-surface-var italic">Not yet assigned.</p>
            <% } %>

            <% if (currentUser.role === 'IT_MANAGER' && ticket.currentStatus !== 'CLOSED') { %>
            <details class="mt-4 border-t border-outline-var pt-4">
                <summary class="cursor-pointer text-xs font-semibold uppercase tracking-wider text-primary">
                    <%= assignment ? 'Reassign Ticket' : 'Assign Ticket' %>
                </summary>
                <form method="post" action="/tickets/<%= ticket.id %>/assign" class="mt-3 space-y-2">
                    <select name="agentUserId" required
                            class="w-full px-2.5 py-2 border border-outline-var rounded text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary">
                        <option value="">Select agent</option>
                        <% agents.forEach(a => { %>
                            <option value="<%= a.id %>"><%= a.name %></option>
                        <% }) %>
                    </select>
                    <% if (assignment) { %>
                    <input type="text" name="reason" placeholder="Reason for reassignment"
                           class="w-full px-2.5 py-2 border border-outline-var rounded text-sm focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary">
                    <% } %>
                    <button type="submit"
                            class="w-full bg-primary hover:bg-primary-dark text-white text-xs font-semibold uppercase tracking-wider py-2 rounded">
                        Assign
                    </button>
                </form>
            </details>
            <% } %>
        </div>

        <!-- History card with stepped visual -->
        <div class="bg-surface-card border border-outline-var rounded-lg p-5">
            <div class="text-[11px] uppercase tracking-wider text-on-surface-var font-semibold mb-4">History</div>
            <ol class="relative">
                <% statusChanges.slice().reverse().forEach((s, idx) => {
                    const isLast = idx === statusChanges.length - 1;
                    const isCurrent = idx === 0;
                %>
                <li class="pb-4 pl-7 relative <%= isLast ? '' : 'border-l-2 border-outline-var ml-2' %>">
                    <span class="absolute -left-0 top-0 w-4 h-4 rounded-full border-2 <%= isCurrent ? 'border-primary bg-primary' : 'border-outline-var bg-surface-card' %>"></span>
                    <% if (s.previous_status) { %>
                        <div class="text-sm"><span class="text-on-surface-var">Status changed to</span> <strong><%= s.new_status.replace('_', ' ') %></strong></div>
                    <% } else { %>
                        <div class="text-sm"><strong>Ticket Created</strong></div>
                    <% } %>
                    <div class="text-xs text-on-surface-var mt-0.5 font-mono"><%= s.changed_at %> · by <%= s.changer_name %></div>
                </li>
                <% }) %>
            </ol>
        </div>

    </aside>
</div>

<p class="mt-8">
    <a href="/" class="text-sm text-primary hover:underline flex items-center gap-1 inline-flex">
        <span class="material-symbols-outlined text-base">arrow_back</span> Back to dashboard
    </a>
</p>

<%- include('partials/footer') %>
